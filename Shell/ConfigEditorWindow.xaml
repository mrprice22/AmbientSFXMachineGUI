<Window x:Class="AmbientSFXMachineGUI.Shell.ConfigEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Config"
        Width="380"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="OnLoaded">
    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1E1E1E" Padding="12,8">
            <TextBlock x:Name="TitleBlock" Foreground="White" FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Validation error bar (hidden until Save fails) -->
        <Border x:Name="ErrorBar" DockPanel.Dock="Bottom" Background="#6E1E1E" Padding="10,6"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="#FFCCCC" TextWrapping="Wrap" FontSize="11"/>
        </Border>

        <!-- Footer buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="8,6">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="OnCancelClick"/>
            <Button Content="Save"   Width="80" Click="OnSaveClick"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,4,8,4">

                <!-- ── Playback ── -->
                <GroupBox Header="Playback" Margin="0,4,0,4">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <ComboBox x:Name="ModeCombo" Grid.Row="0" Grid.Column="1" Margin="0,4">
                            <ComboBoxItem Content="random"/>
                            <ComboBoxItem Content="sequential"/>
                            <ComboBoxItem Content="shuffle"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Enabled"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <CheckBox x:Name="EnabledCheck" Grid.Row="1" Grid.Column="1"
                                  VerticalAlignment="Center" Margin="0,4"/>
                    </Grid>
                </GroupBox>

                <!-- ── Volume ── -->
                <GroupBox Header="Volume" Margin="0,0,0,4">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Volume (0 – 100)"
                                   VerticalAlignment="Center"/>
                        <Slider x:Name="VolumeSlider" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnVolumeSliderChanged"/>
                        <TextBox x:Name="VolumeBox" Grid.Column="2"
                                 Margin="4,0,0,0" VerticalContentAlignment="Center"
                                 TextChanged="OnVolumeBoxChanged"/>
                    </Grid>
                </GroupBox>

                <!-- ── Timing ── -->
                <GroupBox Header="Timing" Margin="0,0,0,4">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Min Minutes"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="MinMinutesBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Text="Max Minutes"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="MaxMinutesBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Text="Min Seconds"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="MinSecondsBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Text="Max Seconds"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="MaxSecondsBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="4" Text="Override Startup (s)"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="OverrideStartupBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/>
                    </Grid>
                </GroupBox>

                <!-- ── Balance ── -->
                <GroupBox Header="Balance  (0 = full-left · 50 = center · 100 = full-right)" Margin="0,0,0,4">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Balance Min"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <Slider x:Name="BalanceMinSlider" Grid.Row="0" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnBalanceMinSliderChanged"/>
                        <TextBox x:Name="BalanceMinBox" Grid.Row="0" Grid.Column="2"
                                 Margin="4,4,0,4" VerticalContentAlignment="Center"
                                 TextChanged="OnBalanceMinBoxChanged"/>

                        <TextBlock Grid.Row="1" Text="Balance Max"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <Slider x:Name="BalanceMaxSlider" Grid.Row="1" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnBalanceMaxSliderChanged"/>
                        <TextBox x:Name="BalanceMaxBox" Grid.Row="1" Grid.Column="2"
                                 Margin="4,4,0,4" VerticalContentAlignment="Center"
                                 TextChanged="OnBalanceMaxBoxChanged"/>

                        <TextBlock Grid.Row="2" Text="Invert Chance %"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <Slider x:Name="InvertChanceSlider" Grid.Row="2" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnInvertChanceSliderChanged"/>
                        <TextBox x:Name="InvertChanceBox" Grid.Row="2" Grid.Column="2"
                                 Margin="4,4,0,4" VerticalContentAlignment="Center"
                                 TextChanged="OnInvertChanceBoxChanged"/>
                    </Grid>
                </GroupBox>

                <!-- ── Turbo ── -->
                <GroupBox Header="Turbo" Margin="0,0,0,8">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Turbo Chance %"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <Slider x:Name="TurboChanceSlider" Grid.Row="0" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnTurboChanceSliderChanged"/>
                        <TextBox x:Name="TurboChanceBox" Grid.Row="0" Grid.Column="2"
                                 Margin="4,4,0,4" VerticalContentAlignment="Center"
                                 TextChanged="OnTurboChanceBoxChanged"/>

                        <TextBlock Grid.Row="1" Text="Min Fires"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="TurboMinFiresBox" Grid.Row="1" Grid.Column="1"
                                 Grid.ColumnSpan="2" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Text="Max Fires"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="TurboMaxFiresBox" Grid.Row="2" Grid.Column="1"
                                 Grid.ColumnSpan="2" Margin="0,4"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
