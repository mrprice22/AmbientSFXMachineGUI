<Window x:Class="AmbientSFXMachineGUI.Shell.MiniModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AmbientAgents Mini"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Fill" Value="#4CAF50"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Fill" Value="#555"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsInTurboMode}" Value="True">
                    <Setter Property="Fill" Value="#FFB300"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="#222" CornerRadius="6" BorderBrush="#444" BorderThickness="1" Padding="6"
            MouseLeftButtonDown="OnDragArea">
        <DockPanel>
            <Button DockPanel.Dock="Right" Content="✕" Width="22" Height="22"
                    Background="Transparent" Foreground="#CCC" BorderThickness="0"
                    Click="OnClose" ToolTip="Close mini mode"/>
            <ComboBox DockPanel.Dock="Right" Width="78" Margin="4,0"
                      SelectedIndex="{Binding EdgeIndex, Mode=TwoWay}"
                      ToolTip="Dock edge">
                <ComboBoxItem Content="Float"/>
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Top"/>
                <ComboBoxItem Content="Right"/>
                <ComboBoxItem Content="Bottom"/>
            </ComboBox>
            <TextBlock DockPanel.Dock="Left" Text="Vol" Foreground="#CCC"
                       VerticalAlignment="Center" Margin="4,0"/>
            <Slider DockPanel.Dock="Left" Width="90" Minimum="0" Maximum="100"
                    Value="{Binding MasterVolume, Mode=TwoWay}"
                    VerticalAlignment="Center"/>
            <ToggleButton DockPanel.Dock="Left" Content="M" Width="22" Height="22" Margin="4,0"
                          IsChecked="{Binding IsMutedAll, Mode=TwoWay}" ToolTip="Mute all"/>
            <ItemsControl ItemsSource="{Binding Agents}" Margin="8,0,4,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="3,0"
                                    ToolTip="{Binding Name}">
                            <Ellipse Style="{StaticResource StatusDot}"/>
                            <TextBlock Text="{Binding Name}" Foreground="#DDD"
                                       VerticalAlignment="Center" Margin="4,0,0,0"
                                       FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</Window>
