<Window x:Class="AmbientSFXMachineGUI.Shell.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkey Bindings"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap">
            Click <Bold>Rebind</Bold> and press a key combination. Press <Bold>Escape</Bold> to cancel, <Bold>Delete</Bold> to clear.
        </TextBlock>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Width="80" Click="OnCloseClick"/>
        </StackPanel>
        <DataGrid x:Name="Grid"
                  ItemsSource="{Binding}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Action" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Scope"  Binding="{Binding Scope}"       Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Shortcut" Binding="{Binding Combo}"     Width="140" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Rebind" Width="60" Margin="2" Click="OnRebindClick"/>
                                <Button Content="Clear"  Width="50" Margin="2" Click="OnClearClick"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
