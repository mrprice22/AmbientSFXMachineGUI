<Window x:Class="AmbientSFXMachineGUI.Shell.AddToAgentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add to agents"
        Width="460" Height="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <TextBlock x:Name="PromptText" DockPanel.Dock="Top"
                   Margin="0,0,0,6" TextWrapping="Wrap" FontWeight="SemiBold"/>
        <TextBlock x:Name="SubText" DockPanel.Dock="Top"
                   Margin="0,0,0,8" Opacity="0.6" FontSize="11" TextTrimming="CharacterEllipsis"/>
        <TextBox x:Name="FilterBox" DockPanel.Dock="Top" Margin="0,0,0,6"
                 TextChanged="OnFilterChanged"
                 ToolTip="Filter agents"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.65"/>
            <Button Content="Add" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnAddClick"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>

        <ListBox x:Name="PickList"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                       Margin="0,6,0,2" Opacity="0.75"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Content="{Binding AgentName}"
                              Margin="4,1,0,1"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
