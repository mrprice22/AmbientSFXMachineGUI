<Window x:Class="AmbientSFXMachineGUI.Shell.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Press shortcut"
        Width="360" Height="160"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        KeyDown="OnKeyDown">
    <StackPanel Margin="16" VerticalAlignment="Center">
        <TextBlock Text="Press the key combination you want to bind."
                   TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBlock x:Name="PreviewText"
                   Text="(waiting for input)"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,4,0,4"/>
        <TextBlock Text="Esc = cancel"
                   Foreground="Gray" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
