<UserControl x:Class="AmbientSFXMachineGUI.Panels.NowPlayingPanel.NowPlayingPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <DockPanel>
        <!-- Header: collapse/expand toggle + summary line -->
        <Border DockPanel.Dock="Top" Background="#1F1F1F" Padding="6,3"
                TextElement.Foreground="#DDDDDD">
            <DockPanel>
                <ToggleButton x:Name="CollapseToggle"
                              DockPanel.Dock="Left"
                              IsChecked="True"
                              Width="22" Height="22"
                              ToolTip="Expand / collapse the active sound cards"
                              Content="▾"/>
                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold">
                    <Run Text="{Binding ActivePlaybacks.Count, Mode=OneWay, FallbackValue=0}"/>
                    <Run Text="sound(s) playing"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Master" VerticalAlignment="Center" Margin="8,0,4,0" Opacity="0.8"/>
                    <Slider Width="100" Minimum="0" Maximum="100"
                            Value="{Binding MasterVolume, Mode=TwoWay}"/>
                    <TextBlock VerticalAlignment="Center" Margin="4,0,0,0" Width="30"
                               Text="{Binding MasterVolume, StringFormat={}{0:0}%}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body: card list (collapsed when toggle unchecked) -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsChecked, ElementName=CollapseToggle, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding ActivePlaybacks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4" Padding="6" BorderBrush="#444" BorderThickness="1" CornerRadius="3"
                                TextElement.Foreground="#DDDDDD">
                            <DockPanel Width="280">
                                <!-- Compact vertical "rotary-style" volume slider on the right edge -->
                                <Grid DockPanel.Dock="Right" Width="42" Margin="6,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Slider Grid.Row="0"
                                            Orientation="Vertical"
                                            Minimum="0" Maximum="200"
                                            SmallChange="1" LargeChange="10"
                                            TickFrequency="100" TickPlacement="BottomRight"
                                            Value="{Binding Volume, Mode=TwoWay}"
                                            HorizontalAlignment="Center"
                                            ToolTip="Live volume for this sound (0–200%)"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Volume, StringFormat={}{0:0}%}"
                                               HorizontalAlignment="Center"
                                               FontSize="10" Opacity="0.8"/>
                                </Grid>
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <ToggleButton DockPanel.Dock="Right"
                                                      Content="Solo"
                                                      Width="44" Height="20" Padding="0"
                                                      FontSize="10"
                                                      IsChecked="{Binding IsSoloed, Mode=OneWay}"
                                                      Command="{Binding DataContext.ToggleSoloCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      ToolTip="Mute all other agents until this sound ends"/>
                                        <TextBlock Text="{Binding AgentName}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                                    <ProgressBar Minimum="0"
                                                 Maximum="{Binding Duration.TotalMilliseconds}"
                                                 Value="{Binding Position.TotalMilliseconds}"
                                                 Height="6" Margin="0,4,0,2"/>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Position, StringFormat={}{0:mm\\:ss}}"
                                                   Opacity="0.7" FontSize="11"/>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Duration, StringFormat={}{0:mm\\:ss}}"
                                                   Opacity="0.7" FontSize="11"/>
                                    </DockPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
