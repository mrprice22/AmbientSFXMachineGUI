<UserControl x:Class="AmbientSFXMachineGUI.Panels.NowPlayingPanel.NowPlayingPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ItemsControl ItemsSource="{Binding ActivePlaybacks}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Margin="4" Padding="6" BorderBrush="#444" BorderThickness="1" CornerRadius="3">
                    <StackPanel Width="220">
                        <TextBlock Text="{Binding AgentName}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" Opacity="0.7"/>
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding Duration.TotalMilliseconds}"
                                     Value="{Binding Position.TotalMilliseconds}"
                                     Height="6"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Solo"/>
                            <Slider Minimum="0" Maximum="100" Value="100"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
