<UserControl x:Class="AmbientSFXMachineGUI.Panels.AgentPanel.AgentPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Agents}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="6" Padding="8" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <ToggleButton DockPanel.Dock="Right" Content="On"
                                              IsChecked="{Binding IsEnabled}"/>
                            </DockPanel>
                            <TextBlock Text="{Binding Mode}" Opacity="0.7"/>
                            <Slider Minimum="0" Maximum="100" Value="{Binding Volume}"/>
                            <TextBlock Text="{Binding NextPlayIn, StringFormat=Next in \{0:mm\\:ss\}}"/>
                            <TextBlock Text="{Binding LastPlayedFile}" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Content="Force Play"
                                        Command="{Binding ForcePlayCommand}"/>
                                <Button DockPanel.Dock="Right" Content="Config"
                                        Command="{Binding OpenConfigEditorCommand}"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
