<UserControl x:Class="AmbientSFXMachineGUI.Panels.MachinesRailPanel.MachinesRailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AmbientSFXMachineGUI.Controls">
    <UserControl.Resources>
        <controls:StringToImageSourceConverter x:Key="PathToImage"/>
    </UserControl.Resources>
    <DockPanel>
        <Button DockPanel.Dock="Bottom" Content="+ Import Machine"
                Command="{Binding ImportMachineCommand}"
                Margin="4,4,4,6" Padding="4,3"/>
        <ListBox ItemsSource="{Binding Machines}"
                 SelectedItem="{Binding SelectedMachine, Mode=TwoWay}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="6,5" Margin="2,1">
                        <StackPanel>
                            <!-- Icon + Name + Enable toggle -->
                            <DockPanel LastChildFill="True">
                                <ToggleButton DockPanel.Dock="Right"
                                              Content="On" IsChecked="{Binding IsEnabled}"
                                              MinWidth="34" FontSize="10" Padding="3,1"/>
                                <Image DockPanel.Dock="Left"
                                       Source="{Binding IconPath, Converter={StaticResource PathToImage}}"
                                       Width="20" Height="20" Margin="0,0,5,0"
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IconPath}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" FontSize="13"/>
                            </DockPanel>
                            <!-- Master Volume -->
                            <DockPanel Margin="0,5,0,0">
                                <TextBlock DockPanel.Dock="Left" Text="Vol"
                                           FontSize="10" Opacity="0.55"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding MasterVolume, StringFormat={}{0:0}}"
                                           FontSize="10" Opacity="0.55"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <Slider Minimum="0" Maximum="100"
                                        Value="{Binding MasterVolume}"
                                        VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
