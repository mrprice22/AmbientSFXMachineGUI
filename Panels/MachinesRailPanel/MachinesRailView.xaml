<UserControl x:Class="AmbientSFXMachineGUI.Panels.MachinesRailPanel.MachinesRailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AmbientSFXMachineGUI.Controls">
    <UserControl.Resources>
        <controls:StringToImageSourceConverter x:Key="PathToImage"/>
    </UserControl.Resources>
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4,4,6">
            <Button Content="+ New"    Command="{Binding CreateMachineCommand}"
                    Padding="4,3" Margin="0,0,4,0" MinWidth="52"/>
            <Button Content="+ Import" Command="{Binding ImportMachineCommand}"
                    Padding="4,3"/>
        </StackPanel>
        <ListBox x:Name="MachinesList"
                 ItemsSource="{Binding Machines}"
                 SelectedItem="{Binding SelectedMachine, Mode=TwoWay}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="OnListPreviewMouseLeftButtonDown"
                 MouseMove="OnListMouseMove"
                 Drop="OnListDrop">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Tag carries ShellViewModel so the context menu can reach its commands -->
                    <Border Padding="6,5" Margin="2,1"
                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="New agent…"
                                          Command="{Binding PlacementTarget.Tag.CreateAgentCommand,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="Rename…"
                                          Command="{Binding PlacementTarget.Tag.RenameMachineCommand,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Change icon…"
                                          Command="{Binding PlacementTarget.Tag.ChangeIconCommand,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="Remove machine"
                                          Command="{Binding PlacementTarget.Tag.DeleteMachineCommand,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel>
                            <!-- Icon + Name + Enable toggle -->
                            <DockPanel LastChildFill="True">
                                <ToggleButton DockPanel.Dock="Right"
                                              Content="On" IsChecked="{Binding IsEnabled}"
                                              MinWidth="34" FontSize="10" Padding="3,1"/>
                                <Image DockPanel.Dock="Left"
                                       Source="{Binding ResolvedIconPath, Converter={StaticResource PathToImage}}"
                                       Width="20" Height="20" Margin="0,0,5,0"
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IconPath}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" FontSize="13"/>
                            </DockPanel>
                            <!-- Master Volume -->
                            <DockPanel Margin="0,5,0,0">
                                <TextBlock DockPanel.Dock="Left" Text="Vol"
                                           FontSize="10" Opacity="0.55"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding MasterVolume, StringFormat={}{0:0}}"
                                           FontSize="10" Opacity="0.55"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <Slider Minimum="0" Maximum="100"
                                        Value="{Binding MasterVolume}"
                                        VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
