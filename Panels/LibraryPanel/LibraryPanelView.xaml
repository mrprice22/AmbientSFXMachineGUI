<UserControl x:Class="AmbientSFXMachineGUI.Panels.LibraryPanel.LibraryPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:AmbientSFXMachineGUI.Controls">
    <UserControl.Resources>
        <ctl:ByteSizeConverter x:Key="ByteSize"/>
        <ctl:TimeSpanConverter x:Key="Duration"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0">
            <TabItem Header="All Files">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="4">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,4,0"
                                   Opacity="0.7">
                            <Run Text="{Binding LibraryView.Count, Mode=OneWay, FallbackValue=0}"/><Run Text=" files"/>
                        </TextBlock>
                        <TextBox Text="{Binding LibraryFilter, UpdateSourceTrigger=PropertyChanged, Delay=150}"/>
                    </DockPanel>
                    <ListView x:Name="FilesList"
                              ItemsSource="{Binding LibraryView}"
                              SelectedItem="{Binding SelectedLibraryEntry, Mode=TwoWay}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              GridViewColumnHeader.Click="OnHeaderClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="220" DisplayMemberBinding="{Binding FileName}">
                                    <GridViewColumnHeader Content="File" Tag="FileName"/>
                                </GridViewColumn>
                                <GridViewColumn Width="80"
                                                DisplayMemberBinding="{Binding Duration, Converter={StaticResource Duration}}">
                                    <GridViewColumnHeader Content="Duration" Tag="Duration"/>
                                </GridViewColumn>
                                <GridViewColumn Width="90"
                                                DisplayMemberBinding="{Binding ByteSize, Converter={StaticResource ByteSize}}">
                                    <GridViewColumnHeader Content="Size" Tag="ByteSize"/>
                                </GridViewColumn>
                                <GridViewColumn Width="60"
                                                DisplayMemberBinding="{Binding Usages.Count}">
                                    <GridViewColumnHeader Content="Used" Tag="Usages.Count"/>
                                </GridViewColumn>
                                <GridViewColumn Width="600" DisplayMemberBinding="{Binding AbsolutePath}">
                                    <GridViewColumnHeader Content="Path" Tag="AbsolutePath"/>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run Text="Duplicates"/>
                        <Run Text=" ("/><Run Text="{Binding LibraryDuplicates.ExactGroups.Count, Mode=OneWay, FallbackValue=0}"/><Run Text="+"/><Run Text="{Binding LibraryDuplicates.LikelyGroups.Count, Mode=OneWay, FallbackValue=0}"/><Run Text=")"/>
                    </TextBlock>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <TextBlock Text="Exact duplicates (identical SHA-256)"
                                   FontWeight="Bold" Margin="0,4,0,4"/>
                        <ItemsControl ItemsSource="{Binding LibraryDuplicates.ExactGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#40808080" BorderThickness="0,0,0,1" Margin="0,2,0,2" Padding="0,2,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Opacity="0.85"/>
                                            <ItemsControl ItemsSource="{Binding Entries}" Margin="12,2,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1,0,1" Background="Transparent">
                                                            <Grid.InputBindings>
                                                                <MouseBinding Gesture="LeftClick"
                                                                              Command="{Binding DataContext.SelectLibraryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Grid.InputBindings>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="60"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding AbsolutePath}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding ByteSize, Converter={StaticResource ByteSize}}" TextAlignment="Right"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Duration, Converter={StaticResource Duration}}" TextAlignment="Right"/>
                                                            <TextBlock Grid.Column="3" TextAlignment="Right">
                                                                <Run Text="{Binding Usages.Count, Mode=OneWay}"/><Run Text=" uses"/>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(none)"
                                   Opacity="0.5" Margin="0,2,0,8"
                                   Visibility="{Binding LibraryDuplicates.ExactGroups.Count, Converter={x:Static ctl:ZeroToVisibleConverter.Instance}}"/>

                        <TextBlock Text="Likely duplicates (same name, duration ±1%)"
                                   FontWeight="Bold" Margin="0,12,0,4"/>
                        <ItemsControl ItemsSource="{Binding LibraryDuplicates.LikelyGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#40808080" BorderThickness="0,0,0,1" Margin="0,2,0,2" Padding="0,2,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Opacity="0.85"/>
                                            <ItemsControl ItemsSource="{Binding Entries}" Margin="12,2,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1,0,1" Background="Transparent">
                                                            <Grid.InputBindings>
                                                                <MouseBinding Gesture="LeftClick"
                                                                              Command="{Binding DataContext.SelectLibraryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Grid.InputBindings>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="60"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding AbsolutePath}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding ByteSize, Converter={StaticResource ByteSize}}" TextAlignment="Right"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Duration, Converter={StaticResource Duration}}" TextAlignment="Right"/>
                                                            <TextBlock Grid.Column="3" TextAlignment="Right">
                                                                <Run Text="{Binding Usages.Count, Mode=OneWay}"/><Run Text=" uses"/>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(none)"
                                   Opacity="0.5" Margin="0,2,0,8"
                                   Visibility="{Binding LibraryDuplicates.LikelyGroups.Count, Converter={x:Static ctl:ZeroToVisibleConverter.Instance}}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run Text="Unused"/>
                        <Run Text=" ("/><Run Text="{Binding UnusedView.Count, Mode=OneWay, FallbackValue=0}"/><Run Text=")"/>
                    </TextBlock>
                </TabItem.Header>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="4">
                        <Button Content="Remove selected from library"
                                Command="{Binding RemoveUnusedCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=UnusedList}"
                                Padding="8,2"/>
                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,4,0"
                                   Opacity="0.7">
                            <Run Text="{Binding UnusedView.Count, Mode=OneWay, FallbackValue=0}"/><Run Text=" unused files"/>
                        </TextBlock>
                        <TextBlock/>
                    </DockPanel>
                    <ListView x:Name="UnusedList"
                              ItemsSource="{Binding UnusedView}"
                              SelectedItem="{Binding SelectedLibraryEntry, Mode=TwoWay}"
                              SelectionMode="Extended"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.IsDeferredScrollingEnabled="True">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File" Width="220" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="Duration" Width="80"
                                                DisplayMemberBinding="{Binding Duration, Converter={StaticResource Duration}}"/>
                                <GridViewColumn Header="Size" Width="90"
                                                DisplayMemberBinding="{Binding ByteSize, Converter={StaticResource ByteSize}}"/>
                                <GridViewColumn Header="Path" Width="600" DisplayMemberBinding="{Binding AbsolutePath}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Column="1" Width="300" BorderBrush="#40808080" BorderThickness="1,0,0,0"
                Background="#10808080">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedLibraryEntry}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel Margin="8">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="✕" Width="22" Height="22"
                            Command="{Binding CloseUsagesDrawerCommand}"
                            ToolTip="Close"/>
                    <TextBlock Text="Usages" FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedLibraryEntry.FileName}"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding SelectedLibraryEntry.AbsolutePath}"/>
                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedLibraryEntry.AbsolutePath}"
                           Opacity="0.6" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,4" Opacity="0.75">
                    <Run Text="Referenced by "/><Run Text="{Binding SelectedEntryUsages.Count, Mode=OneWay}"/><Run Text=" agent(s)"/>
                </TextBlock>
                <TextBlock DockPanel.Dock="Top" Text="(no usages)" Opacity="0.5"
                           Visibility="{Binding SelectedEntryUsages.Count, Converter={x:Static ctl:ZeroToVisibleConverter.Instance}}"/>
                <ListBox ItemsSource="{Binding SelectedEntryUsages}"
                         BorderThickness="0" Background="Transparent"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="4" Margin="0,1,0,1" BorderBrush="#30808080" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Go"
                                            Command="{Binding NavigateCommand}"
                                            Padding="8,1" Margin="6,0,0,0"
                                            ToolTip="Focus this agent card"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AgentName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding MachineName}" Opacity="0.65" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
