<UserControl x:Class="AmbientSFXMachineGUI.Controls.PanIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="80" Height="44">
    <Canvas>
        <!-- Arc track: semicircle from bottom-left to bottom-right -->
        <Path Data="M 2,42 A 38,38 0 0 0 78,42"
              Stroke="#555" StrokeThickness="2" Fill="Transparent"
              StrokeLineJoin="Round"/>
        <!-- L / R corner labels -->
        <TextBlock Text="L" Canvas.Left="1"  Canvas.Top="32"
                   FontSize="9" Foreground="#666"/>
        <TextBlock Text="R" Canvas.Left="68" Canvas.Top="32"
                   FontSize="9" Foreground="#666"/>
        <!-- Pan indicator dot (positioned in code-behind) -->
        <Ellipse x:Name="PanDot" Width="10" Height="10" Fill="#4A9EFF"/>
    </Canvas>
</UserControl>
